# Production — Hetzner Object Storage + remote PostgreSQL
# Copy to .env.prod, fill in values, never commit .env.prod
# Usage: source .env.prod && pixi run prod-up && pixi run shell

# ── PostgreSQL (your remote instance — Hetzner VPS, Supabase, Neon, etc.) ─────
POSTGRES_HOST=YOUR_POSTGRES_HOST      # e.g. 1.2.3.4 or db.example.com
POSTGRES_PORT=5432
POSTGRES_PASSWORD=YOUR_POSTGRES_PASSWORD

# ── Hetzner Object Storage ────────────────────────────────────────────────────
# Keys: Hetzner Cloud Console → Object Storage → Manage keys
# Endpoint: <region>.your-objectstorage.com  (nbg1 / fsn1 / hel1)
S3_ENDPOINT=nbg1.your-objectstorage.com
S3_ACCESS_KEY_ID=YOUR_HETZNER_ACCESS_KEY
S3_SECRET_ACCESS_KEY=YOUR_HETZNER_SECRET_KEY
S3_BUCKET=ducklake                    # bucket name (will be created if missing)
S3_REGION=eu-central-1               # Hetzner uses this for nbg1/fsn1
S3_USE_SSL=true

# ── Guard (ducklake-guard) — optional ─────────────────────────────────────────
# Create a SECOND Hetzner Object Storage key pair for the reader.
# Never share the admin key (S3_ACCESS_KEY_ID) with readers.
READER_PG_PASSWORD=YOUR_READER_PG_PASSWORD
READER_S3_ACCESS_KEY_ID=YOUR_READER_HETZNER_ACCESS_KEY
READER_S3_SECRET_ACCESS_KEY=YOUR_READER_HETZNER_SECRET_KEY
