# ─── Hetzner Object Storage ───────────────────────────────────────────────────
# Cloud Console → Object Storage → Manage keys
# Endpoint = <location>.your-objectstorage.com (no https://)
# e.g. fsn1.your-objectstorage.com  |  nbg1.your-objectstorage.com
S3_ENDPOINT=fsn1.your-objectstorage.com
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET=ducklake
S3_REGION=eu-central-1
S3_USE_SSL=true

# ─── PostgreSQL (remote Hetzner VPS or managed PG) ────────────────────────────
POSTGRES_HOST=1.2.3.4                  # VPS IP or hostname
POSTGRES_PORT=5432
POSTGRES_PASSWORD=change-me-please
